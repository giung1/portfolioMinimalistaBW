<section class="bg-white py-24 px-6 md:px-20 font-montserrat">
  <div class="max-w-3xl mx-auto">
    <div class="mb-16 text-center">
      <p class="tracking-[0.3em] text-xs text-neutral-400 uppercase mb-3">
        Portfolio | Lucía Tortú
      </p>
      <h2
        class="font-domine text-[clamp(2rem,5vw,3.5rem)] text-black leading-tight"
      >
        Hablemos
      </h2>
      <div class="mt-4 mx-auto w-18 h-px bg-black"></div>
    </div>

    <form
      id="contact-form"
      name="contacto"
      method="POST"
      action="/?success=true"
      class="space-y-8"
      novalidate
      data-netlify="true"
    >
      <input type="hidden" name="form-name" value="contacto" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="form-group relative">
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            autocomplete="name"
            class="peer w-full border-b border-neutral-300 bg-transparent py-3 text-sm text-black placeholder-transparent outline-none transition-all duration-300 focus:border-black"
            placeholder="Nombre"
          />
          <label
            for="nombre"
            class="pointer-events-none absolute left-0 top-3 text-sm text-neutral-400 transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-sm peer-focus:-top-4 peer-focus:text-xs peer-focus:text-black peer-not-placeholder-shown:-top-4 peer-not-placeholder-shown:text-xs"
          >
            Nombre
          </label>
          <span
            class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-300 peer-focus:w-full"
          ></span>
        </div>

        <div class="form-group relative">
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="peer w-full border-b border-neutral-300 bg-transparent py-3 text-sm text-black placeholder-transparent outline-none transition-all duration-300 focus:border-black"
            placeholder="Email"
          />
          <label
            for="email"
            class="pointer-events-none absolute left-0 top-3 text-sm text-neutral-400 transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-sm peer-focus:-top-4 peer-focus:text-xs peer-focus:text-black peer-not-placeholder-shown:-top-4 peer-not-placeholder-shown:text-xs"
          >
            Email
          </label>
          <span
            class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-300 peer-focus:w-full"
          ></span>
        </div>
      </div>

      <div class="form-group relative">
        <input
          type="text"
          id="asunto"
          name="asunto"
          required
          class="peer w-full border-b border-neutral-300 bg-transparent py-3 text-sm text-black placeholder-transparent outline-none transition-all duration-300 focus:border-black"
          placeholder="Asunto"
        />
        <label
          for="asunto"
          class="pointer-events-none absolute left-0 top-3 text-sm text-neutral-400 transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-sm peer-focus:-top-4 peer-focus:text-xs peer-focus:text-black peer-not-placeholder-shown:-top-4 peer-not-placeholder-shown:text-xs"
        >
          Asunto
        </label>
        <span
          class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-300 peer-focus:w-full"
        ></span>
      </div>

      <div class="form-group relative">
        <textarea
          id="mensaje"
          name="mensaje"
          required
          rows="5"
          class="peer w-full resize-none border-b border-neutral-300 bg-transparent py-3 text-sm text-black placeholder-transparent outline-none transition-all duration-300 focus:border-black"
          placeholder="Mensaje"></textarea>
        <label
          for="mensaje"
          class="pointer-events-none absolute left-0 top-3 text-sm text-neutral-400 transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-sm peer-focus:-top-4 peer-focus:text-xs peer-focus:text-black peer-not-placeholder-shown:-top-4 peer-not-placeholder-shown:text-xs"
        >
          Mensaje
        </label>
        <span
          class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-300 peer-focus:w-full"
        ></span>
      </div>

      <p id="form-status" class="hidden text-sm text-center" aria-live="polite">
      </p>

      <div class="pt-4 flex justify-center md:justify-start">
        <button
          type="submit"
          id="submit-btn"
          class="group relative overflow-hidden border border-black bg-black px-12 py-4 text-xs tracking-[0.25em] text-white uppercase transition-all duration-500 hover:bg-white hover:text-black focus:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="btn-text">Enviar mensaje</span>
          <!-- Spinner (oculto) -->
          <span
            id="btn-spinner"
            class="hidden absolute inset-0 flex items-center justify-center"
          >
            <svg
              class="animate-spin h-4 w-4"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8v8z"></path>
            </svg>
          </span>
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  textarea:not(:placeholder-shown) ~ label,
  input:not(:placeholder-shown) ~ label {
    top: -1rem;
    font-size: 0.75rem;
    color: #000;
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text") as HTMLSpanElement;
  const btnSpinner = document.getElementById("btn-spinner") as HTMLSpanElement;
  const formStatus = document.getElementById(
    "form-status",
  ) as HTMLParagraphElement;

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    btnText.classList.toggle("hidden", loading);
    btnSpinner.classList.toggle("hidden", !loading);
  }

  function showStatus(message: string, isError = false) {
    formStatus.textContent = message;
    formStatus.classList.remove("hidden", "text-red-600", "text-green-700");
    formStatus.classList.add(isError ? "text-red-600" : "text-green-700");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    setLoading(true);
    formStatus.classList.add("hidden");

    const data = new URLSearchParams(new FormData(form) as any).toString();

    try {
      const response = await fetch("/", {
        method: "POST",
        body: data,
        headers: {
          "Content-Type": "application/x-www-form-urlencoded",
        },
      });

      if (response.ok) {
        showStatus("¡Mensaje enviado! Me pondré en contacto pronto.");
        form.reset();
      } else {
        showStatus("Algo salió mal. Por favor intentá de nuevo.", true);
      }
    } catch {
      showStatus("Error de conexión. Por favor intentá de nuevo.", true);
    } finally {
      setLoading(false);
    }
  });
</script>
