---
const { pageTitle } = Astro.props;
---

<section class="flex flex-col items-center justify-center p-20 overflow-hidden">
  <div class="group relative w-5/6 aspect-square overflow-hidden">
    <img
      src={`/images/${pageTitle}.jpg`}
      class="h-full w-full object-cover group-hover:scale-110 transition-all duration-800"
      alt=""
    />
    <div
      class="absolute inset-0 bg-black opacity-0 group-hover:opacity-60 transition-opacity duration-800"
    >
    </div>
    <div class="absolute inset-0 flex items-center justify-center">
      <h1
        class="text-6xl text-white opacity-0 group-hover:opacity-100 transition-opacity duration-800 text-center px-4"
      >
        {pageTitle}
      </h1>
    </div>
  </div>
</section>
